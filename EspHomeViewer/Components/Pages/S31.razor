@page "/S31"

@using EspHomeViewer.Components.Control;

<ContextMenu Id="TotalMenu">
    <MenuItemDay OnMenuGraphClickAsync="@OnMenuGraphClickAsync" />
</ContextMenu>

<ContextMenu Id="DeviceMenu">
    @foreach (var status in EsphomeOptions.CurrentValue.StatusInfo)
    {
        <SubMenuDay StatusInfo="@status" OnMenuGraphClickAsync="@OnMenuGraphClickAsync"></SubMenuDay>
    }
</ContextMenu>

<PageTitle>S31 Data</PageTitle>
<table>
    <tbody>
        @foreach (var group in EsphomeOptions.CurrentValue.GroupInfo)
        {
            <tr>
                <td>
                    <ContextMenuTrigger MenuId="TotalMenu" MouseButtonTrigger="MouseButtonTrigger.Left" Id="@group.Id">
                        @group.Title
                    </ContextMenuTrigger>
                </td>
                <td><TotalOutput GroupInfo="@group.Name" Unit="@group.Unit" Subscriber="subscriber" /></td>
            </tr>
        }
    </tbody>
</table>

<table>
    <thead>
        <tr>
            <th>
                Device
            </th>
            @foreach (var status in EsphomeOptions.CurrentValue.StatusInfo.Where(x => !x.Hidden))
            {
                <th>@status.Name</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var device in EsphomeOptions.CurrentValue.DeviceInfo)
        {
            <tr>
                <td>
                    <ContextMenuTrigger Data="@device.DeviceName" MenuId="DeviceMenu" MouseButtonTrigger="MouseButtonTrigger.Left" Id="@device.Name">
                        @device.DeviceName
                    </ContextMenuTrigger>
                </td>
                @foreach (var status in EsphomeOptions.CurrentValue.StatusInfo.Where(x => !x.Hidden))
                {
                    <td><SingleInput DeviceName="@device.DeviceName" Name="@status.Name" Unit="@status.Unit" Subscriber="subscriber" /></td>
                }
            </tr>
        }
    </tbody>
</table>

<table>
    <thead>
        <tr><th colspan="2">Indoor</th><th colspan="2">General Info</th><th colspan="2">Outdoor</th><th colspan="2">Rain</th></tr>
    </thead>
    <tbody>
        <tr>
            <td>Temperature</td><td><p>@TryReadWeatherData("tempinc")</p></td>
            <td>Date Time</td><td><p>@TryReadWeatherData("datelocal")</p></td>
            <td>Temperature</td><td><p>@TryReadWeatherData("tempc")</p></td>
            <td>Current Rain</td><td><p>@TryReadWeatherData("rrain_piezomm")</p></td>
        </tr>
        <tr>
            <td>Humididy</td><td><p>@TryReadWeatherData("humidityin")</p></td>
            <td>Runtime</td><td><p>@TryReadWeatherData("runtime")</p></td>
            <td>Humididy</td><td><p>@TryReadWeatherData("humidity")</p></td>
            <td>Event Rain</td><td><p>@TryReadWeatherData("erain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td>WS90 Capacitor</td><td><p>@TryReadWeatherData("ws90cap_volt")</p></td>
            <td>Wind Direction</td><td><p>@TryReadWeatherData("winddircardinal")</p></td>
            <td>Hourly Rain</td><td><p>@TryReadWeatherData("hrain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td>AA Batteries</td><td><p>@TryReadWeatherData("wh90batt")</p></td>
            <td>Wind Speed</td><td><p>@TryReadWeatherData("windspeedkmh")</p></td>
            <td>Daily Rain</td><td><p>@TryReadWeatherData("drain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>Wind Gust</td><td><p>@TryReadWeatherData("windgustkmh")</p></td>
            <td>Weekly Rain</td><td><p>@TryReadWeatherData("wrain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>Wind Max</td><td><p>@TryReadWeatherData("maxdailykmh")</p></td>
            <td>Monthly Rain</td><td><p>@TryReadWeatherData("mrain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>Solar Radiation</td><td><p>@TryReadWeatherData("solarradiation")</p></td>
            <td>Yearly Rain</td><td><p>@TryReadWeatherData("yrain_piezomm")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>UV</td><td><p>@TryReadWeatherData("uv")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>Barometer Absolute</td><td><p>@TryReadWeatherData("baromabshpa")</p></td>
        </tr>
        <tr><td colspan="2" style="border: none"></td>
            <td colspan="2" style="border: none"></td>
            <td>Barometer Relative</td><td><p>@TryReadWeatherData("baromrelhpa")</p></td>
        </tr>
    </tbody>
</table>